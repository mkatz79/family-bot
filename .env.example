# ─── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Twilio ─────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=+14155238886   # Twilio sandbox number (or your registered number)

# The WhatsApp number/group to send outbound messages to.
# For sandbox: the phone number you joined with, e.g. +15551234567
# Format: +1XXXXXXXXXX (no "whatsapp:" prefix needed here)
WHATSAPP_GROUP_ID=+1XXXXXXXXXX

# ─── Google Calendar ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob
GOOGLE_REFRESH_TOKEN=1//...   # Run: node scripts/google-auth.js to get this

# The calendar to use — "primary" uses the main calendar of the authenticated account.
# Or paste a specific calendar ID from Google Calendar settings.
GOOGLE_CALENDAR_ID=primary

# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
